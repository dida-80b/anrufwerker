{
  "$schema": "https://anrufwerker.dev/schemas/tenant.schema.json",
  "tenant_id": "tenant_example_001",
  "name": "Sample Trade Services Ltd.",
  "business_type": "trades",
  "language": "en-US",
  "timezone": "Europe/Berlin",
  "phone": {
    "fallback_transfer": "+49XXXXXXXXX",
    "business_hours": {
      "timezone": "Europe/Berlin",
      "monday": {
        "start": "08:00",
        "end": "17:00"
      },
      "tuesday": {
        "start": "08:00",
        "end": "17:00"
      },
      "wednesday": {
        "start": "08:00",
        "end": "17:00"
      },
      "thursday": {
        "start": "08:00",
        "end": "17:00"
      },
      "friday": {
        "start": "08:00",
        "end": "16:00"
      },
      "saturday": null,
      "sunday": null
    },
    "after_hours_behavior": "voicemail",
    "did_numbers": [
      "+49XXXXXXXXX"
    ]
  },
  "greeting": {
    "opening": "Hello, you have reached {company_name}. How can I help you?",
    "no_match": "Sorry, I did not catch that. Could you repeat it?",
    "transfer": "One moment, I will connect you to a staff member.",
    "closing": "Thank you for your call. Goodbye."
  },
  "intents": {
    "appointment_request": {
      "enabled": true,
      "priority": 1,
      "description": "Appointment request",
      "slots": [
        "service_type",
        "desired_date",
        "desired_time"
      ],
      "response": "I have noted the requested appointment: {service_type} on {desired_date} at {desired_time}. I will pass this to our team."
    },
    "price_inquiry": {
      "enabled": true,
      "priority": 2,
      "description": "Price inquiry",
      "slots": [
        "service_type"
      ],
      "response": "For a detailed quote for {service_type}, we would need to assess it on site. May I take your name and phone number?"
    },
    "status_inquiry": {
      "enabled": true,
      "priority": 3,
      "description": "Order status",
      "slots": [
        "order_number"
      ],
      "response": "I am checking the status of your order."
    },
    "transfer": {
      "enabled": true,
      "priority": 99,
      "description": "Transfer to staff",
      "response": "I will transfer you now."
    }
  },
  "policies": {
    "allow_direct_booking": false,
    "require_confirmation": true,
    "max_appointment_days": 60,
    "blocked_keywords": [
      "price",
      "cheap",
      "discount"
    ],
    "callback_request": {
      "enabled": true,
      "max_per_day": 3
    }
  },
  "integrations": {
    "contact_adapter": {
      "type": "carddav",
      "config": {
        "url": "${CARDDAV_URL}",
        "username": "${CARDDAV_USERNAME}",
        "password": "${CARDDAV_PASSWORD}"
      }
    },
    "calendar_adapter": {
      "type": "caldav",
      "config": {
        "url": "${CALDAV_URL}",
        "username": "${CALDAV_USERNAME}",
        "password": "${CALDAV_PASSWORD}"
      }
    },
    "crm_adapter": {
      "type": "none",
      "config": {}
    }
  },
  "storage": {
    "transcripts_retention_days": 90,
    "recordings_enabled": false,
    "training_data_opt_in": false
  },
  "model_config": {
    "stt_model": "small",
    "llm_model": "lfm2:24b",
    "llm_temperature": 0.3,
    "llm_max_tokens": 80,
    "tts_model": "silero"
  },
  "outbound_policy": {
    "enabled": false,
    "allowed_use_cases": [
      "appointment_confirmation",
      "missing_information_followup"
    ],
    "max_attempts": 2,
    "require_human_approval_for": [
      "price_negotiation",
      "legal_commitments"
    ]
  }
}
