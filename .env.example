# anrufwerker — Konfiguration
# Kopiere diese Datei: cp .env.example .env
# Dann die Pflichtfelder ausfüllen (markiert mit REQUIRED)

# ===========================================
# Asterisk / ARI  (REQUIRED)
# ===========================================

ASTERISK_HOST=host.docker.internal
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=changeme          # muss mit asterisk/etc/ari.conf übereinstimmen
ASTERISK_ARI_PASSWORD=changeme      # REQUIRED — sicheres Passwort setzen

# ===========================================
# FritzBox SIP  (nur wenn Asterisk mit FritzBox verbunden)
# ===========================================

FRITZBOX_IP=192.168.178.1           # IP der FritzBox im LAN
FRITZBOX_SIP_USER=asterisk
FRITZBOX_SIP_PASSWORD=changeme      # REQUIRED — SIP-Passwort der FritzBox
FRITZBOX_PHONE_NUMBER=              # Rufnummer des Betriebs (optional)
LOCAL_IP=127.0.0.1                  # lokale IP des Servers (für SIP-RTP)

# ===========================================
# LLM / Ollama  (REQUIRED)
# ===========================================

# Ollama läuft auf dem Host, nicht im Container
OLLAMA_URL=http://host.docker.internal:11434/api/chat
OLLAMA_MODEL=qwen2.5:7b             # REQUIRED — Modell muss auf Host geladen sein
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.85
OLLAMA_NUM_PREDICT=80
OLLAMA_REPEAT_PENALTY=1.2
OLLAMA_NUM_CTX=2048

# ===========================================
# TTS — Piper (lokal) oder edge (online)
# ===========================================

# "piper" = lokal, kein Internet nötig (empfohlen)
# "edge"  = Microsoft Azure Neural, benötigt Internet
TTS_ENGINE=piper

# Piper-Stimme — Modell muss in data/piper-voices/ liegen
# Verfügbare deutsche Stimmen: de_DE-thorsten-high, de_DE-thorsten_emotional-medium,
#                               de_DE-ramona-low, de_DE-kerstin-low
PIPER_VOICE=de_DE-thorsten-high
PIPER_URL=http://127.0.0.1:5150

# Edge-TTS Stimme (nur relevant wenn TTS_ENGINE=edge)
TTS_VOICE=de-DE-SeraphinaMultilingualNeural

# ===========================================
# STT — Whisper
# ===========================================

STT_ENGINE=whisper-http
WHISPER_URL=http://127.0.0.1:8090

# ===========================================
# SIP Bridge
# ===========================================

AUDIOSOCKET_PORT=9093
BRIDGE_PORT=5003
INBOUND_ENABLED=true

# Firmenkonfiguration (optional — alternativ über Dashboard pflegen)
# COMPANY_CONFIG=/app/configs/mein-betrieb.json

# ===========================================
# Dashboard Admin (Erststart)
# ===========================================

DEFAULT_ADMIN_EMAIL=admin@anrufwerker.local
DEFAULT_ADMIN_NAME=Administrator
DEFAULT_ADMIN_PASSWORD=anrufwerker-start   # SOFORT nach Login ändern!

# ===========================================
# VAD / Latenz-Tuning (Defaults funktionieren für die meisten Setups)
# ===========================================

VAD_SPEECH_FRAMES_TO_START=2
VAD_SILENCE_FRAMES_TO_END=12
VAD_RMS_THRESHOLD=260
VAD_BARGE_IN_THRESHOLD=2000
VAD_BARGE_IN_FRAMES=50
PREROLL_FRAMES=8
MAX_TTS_SECONDS_PER_SENTENCE=10.0
MAX_TTS_SENTENCES_PER_TURN=2
MAX_TTS_SECONDS_INTRO=8.0
INACTIVITY_TIMEOUT=90
CHECKIN_TIMEOUT=10
MIN_USER_RMS_PROCESS=150

# ===========================================
# Monitoring (optional)
# ===========================================

LOG_LEVEL=INFO
GRAFANA_PASSWORD=admin
