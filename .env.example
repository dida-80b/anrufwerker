# anrufwerker — Configuration
# Copy this file: cp .env.example .env
# Then fill in the required fields (marked with REQUIRED)

# ===========================================
# Asterisk / ARI  (REQUIRED)
# ===========================================

ASTERISK_HOST=host.docker.internal
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=changeme          # must match the Asterisk template configuration
ASTERISK_ARI_PASSWORD=changeme      # REQUIRED — set a secure password

# ===========================================
# SIP trunk  (only needed when Asterisk connects via Fritz!Box or similar)
# ===========================================

FRITZBOX_IP=192.168.178.1           # IP of the Fritz!Box (or SIP gateway) on the LAN
FRITZBOX_SIP_USER=asterisk
FRITZBOX_SIP_PASSWORD=changeme      # REQUIRED — SIP password
FRITZBOX_PHONE_NUMBER=              # business phone number (optional)
LOCAL_IP=127.0.0.1                  # local IP of the server (for SIP/RTP)

# ===========================================
# LLM / Ollama  (REQUIRED)
# ===========================================

# Ollama runs on the host, not in a container
OLLAMA_URL=http://host.docker.internal:11434/api/chat
OLLAMA_MODEL=ministral-3:14b-instruct-2512-q8_0             # REQUIRED — model must be pulled on host
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.85
OLLAMA_NUM_PREDICT=80
OLLAMA_REPEAT_PENALTY=1.2
OLLAMA_NUM_CTX=2048

# ===========================================
# TTS — Piper (local) or edge (online)
# ===========================================

# "piper" = local, no internet required (recommended)
# "edge"  = Microsoft Azure Neural, requires internet
TTS_ENGINE=piper

# Piper voice — model file must be present in data/piper-voices/
# Available German voices: de_DE-thorsten-high, de_DE-thorsten_emotional-medium,
#                          de_DE-ramona-low, de_DE-kerstin-low
PIPER_VOICE=de_DE-thorsten-high
PIPER_URL=http://127.0.0.1:5150

# Edge-TTS voice (only relevant when TTS_ENGINE=edge)
TTS_VOICE=de-DE-SeraphinaMultilingualNeural

# ===========================================
# STT — Whisper
# ===========================================

STT_ENGINE=whisper-http
WHISPER_URL=http://127.0.0.1:8090

# ===========================================
# SIP Bridge
# ===========================================

AUDIOSOCKET_PORT=9093
BRIDGE_PORT=5003
INBOUND_ENABLED=true

# Company configuration (optional — can also be managed via the dashboard)
# COMPANY_CONFIG=/app/configs/my-business.json

# ===========================================
# Dashboard admin (first start)
# ===========================================

DEFAULT_ADMIN_EMAIL=admin@anrufwerker.local
DEFAULT_ADMIN_NAME=Administrator
DEFAULT_ADMIN_PASSWORD=anrufwerker-start   # CHANGE IMMEDIATELY after first login!

# ===========================================
# VAD / latency tuning (defaults work for most setups)
# ===========================================

VAD_SPEECH_FRAMES_TO_START=2
VAD_SILENCE_FRAMES_TO_END=12
VAD_RMS_THRESHOLD=260
VAD_BARGE_IN_THRESHOLD=2000
VAD_BARGE_IN_FRAMES=50
PREROLL_FRAMES=8
MAX_TTS_SECONDS_PER_SENTENCE=10.0
MAX_TTS_SENTENCES_PER_TURN=2
MAX_TTS_SECONDS_INTRO=8.0
INACTIVITY_TIMEOUT=90
CHECKIN_TIMEOUT=10
MIN_USER_RMS_PROCESS=150

# ===========================================
# Monitoring (optional)
# ===========================================

LOG_LEVEL=INFO
GRAFANA_PASSWORD=admin
