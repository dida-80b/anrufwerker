# anrufwerker Environment Configuration
# Copy this file to .env and adjust values for your environment

# ===========================================
# Core Configuration
# ===========================================

TENANT_ID=tenant_example_001
ENVIRONMENT=development

LIVE_ENGINE_PORT=18080
ASYNC_WORKER_PORT=18081

OPENCLAW_ENABLED=false
OPENCLAW_API_URL=http://openclaw:8080
OPENCLAW_API_KEY=changeme

# ===========================================
# LLM / Ollama Configuration
# ===========================================

# Host Ollama (kein Container im anrufwerker-Stack)
OLLAMA_HOST=http://host.docker.internal:11434
LLM_MODEL=lfm2:24b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=80

# ===========================================
# STT / TTS Configuration
# ===========================================

STT_MODEL=small
TTS_MODEL=silero
AUDIO_BUFFER_MS=200

# Low-latency Voice Tuning
VAD_END_SILENCE_MS=300
VAD_MIN_SPEECH_MS=150
VAD_PRE_SPEECH_PADDING_MS=160
STT_PARTIAL_INTERVAL_MS=150
TTS_CHUNK_MS=60
ENABLE_BARGE_IN=true
START_BEEP=false

# ===========================================
# Queue Configuration
# ===========================================

QUEUE_TYPE=sqlite
QUEUE_DSN=/app/data/queue.db

# ===========================================
# Contact / Calendar Adapters
# ===========================================

# CardDAV (Contacts)
CARDDAV_URL=
CARDDAV_USERNAME=
CARDDAV_PASSWORD=

# CalDAV (Calendar)
CALDAV_URL=
CALDAV_USERNAME=
CALDAV_PASSWORD=

# ===========================================
# SIP / Phone Configuration
# ===========================================

# Inbound (Asterisk ARI)
INBOUND_ENABLED=true
ASTERISK_HOST=host.docker.internal
ASTERISK_PORT=5060
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=openclaw
ASTERISK_ARI_PASSWORD=changeme

# Outbound (Asterisk originate)
ASTERISK_ORIGINATE_ENABLED=false
OUTBOUND_CALLER_ID=anrufwerker
SIP_USERNAME=
SIP_PASSWORD=

# FritzBox
FRITZBOX_ENABLED=false
FRITZBOX_URL=http://fritz.box
FRITZBOX_USER=
FRITZBOX_PASSWORD=
FRITZBOX_IP=192.168.178.1
FRITZBOX_SIP_USER=asterisk
FRITZBOX_SIP_PASSWORD=changeme
LOCAL_IP=127.0.0.1

# ===========================================
# Business Hours & Routing
# ===========================================

FALLBACK_TRANSFER_NUMBER=+49XXXXXXXXX

# ===========================================
# Storage
# ===========================================

TRANSCRIPTS_PATH=/app/data/transcripts
TRANSCRIPTS_RETENTION_DAYS=90
RECORDINGS_ENABLED=false
TRAINING_DATA_OPT_IN=false

# ===========================================
# Monitoring
# ===========================================

PROMETHEUS_ENABLED=false
GRAFANA_PASSWORD=admin

# ===========================================
# Security
# ===========================================

API_JWT_SECRET=changeme
RATE_LIMIT_PER_MINUTE=60

# Dashboard bootstrap admin (nur bei leerer DB relevant)
DEFAULT_ADMIN_EMAIL=admin@anrufwerker.local
DEFAULT_ADMIN_NAME=Administrator
DEFAULT_ADMIN_PASSWORD=anrufwerker-start

# ===========================================
# Outbound
# ===========================================

OUTBOUND_ENABLED=false
OUTBOUND_RATE_LIMIT_PER_HOUR=10
OUTBOUND_ALLOWED_HOURS=08:00-18:00
OUTBOUND_REQUIRE_EXPLICIT_MISSION=true

# ===========================================
# SIP Bridge
# ===========================================

SIP_BRIDGE_PORT=5001
SIP_AUDIOSOCKET_PORT=9091
SIP_ASTERISK_HOST=host.docker.internal

# TTS Engine: "piper" (lokal/GPU) oder "edge" (Microsoft Azure, online)
TTS_ENGINE=piper

# Piper Stimme — Modell muss in data/piper-voices/ vorhanden sein:
#   de_DE-thorsten-high              (neutral, hochwertig)
#   de_DE-thorsten_emotional-medium  (emotional)
#   de_DE-ramona-low                 (weiblich)
#   de_DE-kerstin-low                (weiblich)
PIPER_VOICE=de_DE-thorsten-high
PIPER_URL=http://127.0.0.1:5150

# Edge-TTS Stimme (nur wenn TTS_ENGINE=edge)
TTS_VOICE=de-DE-SeraphinaMultilingualNeural
OPENCLAW_INCOMING_WEBHOOK=
FRITZBOX_PHONE_NUMBER=
VOSK_MODEL_PATH=/models/vosk-model-de-0.21
WHISPER_URL=http://127.0.0.1:8090
ALLOW_WHISPER_HTTP_FALLBACK=true
WHISPER_HTTP_PRIMARY=true
OPENCLAW_CHAT_URL=
OPENCLAW_CHAT_TOKEN=
OLLAMA_DIRECT=false
OLLAMA_URL=http://host.docker.internal:11434/api/chat
OLLAMA_MODEL=qwen3.5-tel:latest
COMPANY_CONFIG=/app/configs/malerbetrieb_dannerbeck.json
SIP_INBOUND_ENABLED=false
SIP_COMPANY_CONFIG=/app/configs/malerbetrieb_dannerbeck.json

# Fast Voice Tuning
FAST_STT_MODEL=small
INACTIVITY_TIMEOUT=90
CHECKIN_TIMEOUT=10
VAD_SPEECH_FRAMES_TO_START=2
VAD_SILENCE_FRAMES_TO_END=12
VAD_RMS_THRESHOLD=260
VAD_BARGE_IN_THRESHOLD=2000
VAD_BARGE_IN_FRAMES=50
PREROLL_FRAMES=8
MAX_TTS_SECONDS_PER_SENTENCE=10.0
MAX_TTS_SENTENCES_PER_TURN=2
MAX_TTS_SECONDS_INTRO=8.0
STT_LOGPROB_THRESHOLD=-1.3
NO_REGREET_AFTER_INTRO=false
MIN_USER_RMS_PROCESS=150
PROCESS_BUFFERED_DURING_LLM=false
OLLAMA_TEMPERATURE=0.1
OLLAMA_TOP_P=0.85
OLLAMA_NUM_PREDICT=80
OLLAMA_REPEAT_PENALTY=1.2
OLLAMA_NUM_CTX=2048
