{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://anrufwerker.dev/schemas/transcript_event.schema.json",
  "title": "TranscriptEvent",
  "description": "Schema für einzelne Transcript-Events während eines Live-Anrufs",
  "type": "object",
  "required": [
    "event_id",
    "call_id",
    "timestamp",
    "role",
    "text"
  ],
  "properties": {
    "event_id": {
      "$ref": "#/definitions/uuid",
      "description": "Eindeutige ID dieses Events"
    },
    "call_id": {
      "$ref": "#/definitions/uuid",
      "description": "ID des übergeordneten Anrufs"
    },
    "tenant_id": {
      "type": "string",
      "description": "ID des Tenants"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Zeitstempel des Events (ISO8601)"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0,
      "description": "Sequenznummer des Events im Call"
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "assistant",
        "system"
      ],
      "description": "Sprecher-Rolle"
    },
    "text": {
      "type": "string",
      "description": "Erkannter/gesprochener Text"
    },
    "is_final": {
      "type": "boolean",
      "description": "Ob dies der finale Text ist (false = interim)"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Konfidenz der Spracherkennung"
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "description": "Erkannte Sprache (z.B. de, de-DE)"
    },
    "audio_duration_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Dauer des Audio-Segments in Millisekunden"
    },
    "intent": {
      "type": "object",
      "description": "Erkannter Intent (nur bei assistant role relevant)"
    },
    "slots": {
      "type": "object",
      "description": "Extrahierte Slots (nur bei assistant role relevant)"
    },
    "metadata": {
      "type": "object",
      "description": "Zusätzliche Metadaten"
    },
    "direction": {
      "type": "string",
      "enum": [
        "inbound",
        "outbound"
      ]
    }
  },
  "definitions": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    }
  }
}