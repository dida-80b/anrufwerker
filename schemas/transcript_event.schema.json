{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://anrufwerker.dev/schemas/transcript_event.schema.json",
  "title": "TranscriptEvent",
  "description": "Schema for individual transcript events during a live call",
  "type": "object",
  "required": [
    "event_id",
    "call_id",
    "timestamp",
    "role",
    "text"
  ],
  "properties": {
    "event_id": {
      "$ref": "#/definitions/uuid",
      "description": "Unique ID for this event"
    },
    "call_id": {
      "$ref": "#/definitions/uuid",
      "description": "ID of the parent call"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant ID"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "Event timestamp (ISO8601)"
    },
    "sequence": {
      "type": "integer",
      "minimum": 0,
      "description": "Sequence number of the event within the call"
    },
    "role": {
      "type": "string",
      "enum": [
        "user",
        "assistant",
        "system"
      ],
      "description": "Speaker role"
    },
    "text": {
      "type": "string",
      "description": "Recognized or spoken text"
    },
    "is_final": {
      "type": "boolean",
      "description": "Whether this is the final text (false = interim)"
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Speech recognition confidence"
    },
    "language": {
      "type": "string",
      "pattern": "^[a-z]{2}(-[A-Z]{2})?$",
      "description": "Detected language, for example en or en-US"
    },
    "audio_duration_ms": {
      "type": "integer",
      "minimum": 0,
      "description": "Audio segment duration in milliseconds"
    },
    "intent": {
      "type": "object",
      "description": "Detected intent, relevant only for the assistant role"
    },
    "slots": {
      "type": "object",
      "description": "Extracted slots, relevant only for the assistant role"
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata"
    },
    "direction": {
      "type": "string",
      "enum": [
        "inbound",
        "outbound"
      ]
    }
  },
  "definitions": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    }
  }
}
