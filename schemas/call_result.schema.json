{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://anrufwerker.dev/schemas/call_result.schema.json",
  "title": "CallResult",
  "description": "Schema for the result of a completed call",
  "type": "object",
  "required": [
    "call_id",
    "tenant_id",
    "timestamp_start",
    "direction",
    "timestamp_end",
    "intent",
    "action_required"
  ],
  "properties": {
    "call_id": {
      "$ref": "#/definitions/uuid",
      "description": "Unique ID of the call, also used as the idempotency key"
    },
    "tenant_id": {
      "type": "string",
      "description": "Tenant ID"
    },
    "caller_number": {
      "type": "string",
      "pattern": "^\\+?[0-9]{7,15}$",
      "description": "Caller phone number in E.164 format"
    },
    "caller_name": {
      "type": "string",
      "description": "Optional caller name if identified"
    },
    "timestamp_start": {
      "type": "string",
      "format": "date-time",
      "description": "Call start time (ISO8601)"
    },
    "timestamp_end": {
      "type": "string",
      "format": "date-time",
      "description": "Call end time (ISO8601)"
    },
    "duration_seconds": {
      "type": "integer",
      "minimum": 0,
      "description": "Call duration in seconds"
    },
    "intent": {
      "$ref": "#/definitions/Intent",
      "description": "Detected caller intent"
    },
    "transcript": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/TranscriptEntry"
      },
      "description": "Full transcript of the conversation"
    },
    "summary": {
      "type": "string",
      "maxLength": 500,
      "description": "Optional summary of the call"
    },
    "action_required": {
      "$ref": "#/definitions/ActionRequired",
      "description": "Required follow-up action"
    },
    "callback_scheduled": {
      "type": "boolean",
      "description": "Whether a callback was scheduled"
    },
    "appointment_requested": {
      "type": "boolean",
      "description": "Whether an appointment was requested"
    },
    "recording_url": {
      "type": "string",
      "format": "uri",
      "description": "Recording URL if available and enabled"
    },
    "metadata": {
      "type": "object",
      "description": "Additional metadata"
    },
    "direction": {
      "type": "string",
      "enum": [
        "inbound",
        "outbound"
      ],
      "description": "Call direction"
    },
    "mission_id": {
      "type": "string",
      "description": "Outbound mission ID"
    },
    "mission_type": {
      "type": "string",
      "description": "Mission type, for example appointment_confirmation"
    },
    "mission_status": {
      "type": "string",
      "description": "Outbound mission status"
    }
  },
  "definitions": {
    "uuid": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$"
    },
    "Intent": {
      "type": "object",
      "required": [
        "name",
        "confidence"
      ],
      "properties": {
        "name": {
          "type": "string",
          "enum": [
            "appointment_request",
            "price_inquiry",
            "status_inquiry",
            "complaint",
            "general_inquiry",
            "transfer_request",
            "voicemail",
            "unknown"
          ],
          "description": "Name of the detected intent"
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Intent detection confidence"
        },
        "slots": {
          "$ref": "#/definitions/Slots"
        }
      }
    },
    "Slots": {
      "type": "object",
      "properties": {
        "service_type": {
          "type": "string",
          "description": "Requested service"
        },
        "desired_date": {
          "type": "string",
          "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$",
          "description": "Requested date (YYYY-MM-DD)"
        },
        "desired_time": {
          "type": "string",
          "pattern": "^[0-9]{2}:[0-9]{2}$",
          "description": "Requested time (HH:MM)"
        },
        "caller_name": {
          "type": "string",
          "description": "Caller name"
        },
        "caller_phone": {
          "type": "string",
          "description": "Callback number"
        },
        "address": {
          "type": "string",
          "description": "Customer address"
        },
        "description": {
          "type": "string",
          "description": "Description of the request"
        }
      }
    },
    "TranscriptEntry": {
      "type": "object",
      "required": [
        "role",
        "text"
      ],
      "properties": {
        "role": {
          "type": "string",
          "enum": [
            "user",
            "assistant",
            "system"
          ]
        },
        "text": {
          "type": "string",
          "description": "Spoken or recognized text"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of this entry"
        },
        "intent_partial": {
          "type": "string",
          "description": "Partial intent detected during the call"
        }
      }
    },
    "ActionRequired": {
      "type": "string",
      "enum": [
        "none",
        "callback",
        "appointment_confirmation",
        "transfer",
        "escalation"
      ],
      "description": "Required follow-up action after the call"
    }
  }
}
